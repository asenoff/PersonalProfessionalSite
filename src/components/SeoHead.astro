---
import type { SeoSchemaInput } from "../lib/seo";
import { siteConfig } from "../data/site";
import {
  normalizePath,
  toAbsoluteUrl,
  toIsoDateOrNull,
  toSchemaArray
} from "../lib/seo";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  robots?: string;
  schema?: SeoSchemaInput;
  ogType?: "website" | "article";
  ogImage?: string;
  publishedAt?: string;
}

const {
  title,
  description = siteConfig.defaultDescription,
  canonicalPath = "/",
  robots = "index,follow",
  schema,
  ogType = "website",
  ogImage = "/og-placeholder.svg",
  publishedAt
} = Astro.props;

const fullTitle = title ? `${title} | ${siteConfig.name}` : siteConfig.defaultTitle;
const normalizedCanonicalPath = normalizePath(canonicalPath);
const canonicalUrl = toAbsoluteUrl(normalizedCanonicalPath);
const ogImageUrl = toAbsoluteUrl(ogImage);
const publishedIsoDate = ogType === "article" ? toIsoDateOrNull(publishedAt) : null;
const schemaItems = toSchemaArray(schema);
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="theme-color" content="#0c1016" />
<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="author" content={siteConfig.name} />
<meta name="robots" content={robots} />
<link rel="canonical" href={canonicalUrl} />
<meta property="og:locale" content={siteConfig.seo.locale} />
<meta property="og:site_name" content={siteConfig.name} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:alt" content={siteConfig.seo.defaultOgImageAlt} />
{publishedIsoDate && <meta property="article:published_time" content={publishedIsoDate} />}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:image:alt" content={siteConfig.seo.defaultOgImageAlt} />
{
  schemaItems.map((item) => (
    <script type="application/ld+json" is:inline set:html={JSON.stringify(item)} />
  ))
}
