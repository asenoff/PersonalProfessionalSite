  {name === "copy" && (
    <>
      <rect x="8" y="8" width="10" height="11" rx="1.75" />
      <path d="M6.25 15.5h-.5A1.75 1.75 0 0 1 4 13.75V5.75C4 4.78 4.78 4 5.75 4h8c.97 0 1.75.78 1.75 1.75v.5" />
    </>
  )}

  {name === "graduation" && (
    <>
      <path d="m3.75 9 8.25-4 8.25 4-8.25 4L3.75 9Z" />
      <path d="M7 10.5v4.05c0 .95 2.24 1.95 5 1.95s5-1 5-1.95V10.5" />
