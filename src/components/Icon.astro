        fill="currentColor"
        stroke="none"
        d="M12 3.75a8.25 8.25 0 0 0-2.61 16.08c.41.08.56-.18.56-.4l-.01-1.55c-2.27.49-2.75-.96-2.75-.96-.37-.94-.9-1.19-.9-1.19-.74-.5.06-.49.06-.49.82.06 1.25.84 1.25.84.73 1.25 1.91.89 2.37.68.07-.53.29-.89.52-1.09-1.81-.21-3.71-.91-3.71-4.04 0-.89.32-1.63.84-2.2-.08-.21-.36-1.05.08-2.19 0 0 .69-.22 2.26.84a7.77 7.77 0 0 1 4.11 0c1.57-1.06 2.26-.84 2.26-.84.44 1.14.16 1.98.08 2.19.52.57.84 1.31.84 2.2 0 3.14-1.91 3.83-3.73 4.03.29.25.56.75.56 1.52v2.25c0 .22.15.48.57.4A8.25 8.25 0 0 0 12 3.75Z"
      />
      <circle cx="12" cy="12" r="8.75" />
    </>
  )}

  {name === "clock" && (
    <>
      <circle cx="12" cy="12" r="8.25" />
      <path d="M12 7.5v4.9l3 1.85" />
    </>
  )}

  {name === "briefcase" && (
    <>
      <path d="M8.25 7.25V6A1.75 1.75 0 0 1 10 4.25h4A1.75 1.75 0 0 1 15.75 6v1.25" />
      <path d="M4 8.75h16v8.5A1.75 1.75 0 0 1 18.25 19h-12.5A1.75 1.75 0 0 1 4 17.25v-8.5Z" />
      <path d="M4 11.5a25.6 25.6 0 0 0 8 1.25 25.6 25.6 0 0 0 8-1.25" />
    </>
  )}

  {name === "database" && (
    <>
      <ellipse cx="12" cy="6.25" rx="6.5" ry="2.75" />
      <path d="M5.5 6.25v4.75c0 1.52 2.91 2.75 6.5 2.75s6.5-1.23 6.5-2.75V6.25" />
      <path d="M5.5 11c0 1.52 2.91 2.75 6.5 2.75s6.5-1.23 6.5-2.75" />
      <path d="M5.5 15.25c0 1.52 2.91 2.75 6.5 2.75s6.5-1.23 6.5-2.75V11" />
    </>
  )}

  {name === "layers" && (
    <>
      <path d="m12 4.5 7.25 4L12 12.5 4.75 8.5 12 4.5Z" />
      <path d="m4.75 11.5 7.25 4 7.25-4" />
      <path d="m4.75 14.5 7.25 4 7.25-4" />
