---
import LazyVideoPlayer from "../components/LazyVideoPlayer.astro";
import MainLayout from "../layouts/MainLayout.astro";
import longerPresentationHigh from "../content/videos/longer-presentation-high.mp4?url";
import longerPresentationLow from "../content/videos/longer-presentation-low.mp4?url";
import longerPresentationMedium from "../content/videos/longer-presentation-medium.mp4?url";
import longerPresentationPoster from "../content/videos/longer-presentation-poster.jpg?url";
import shortIntroductionHigh from "../content/videos/short-introduction-high.mp4?url";
import shortIntroductionLow from "../content/videos/short-introduction-low.mp4?url";
import shortIntroductionMedium from "../content/videos/short-introduction-medium.mp4?url";
import shortIntroductionPoster from "../content/videos/short-introduction-poster.jpg?url";

const videos = [
  {
    label: "Video 01",
    title: "Placeholder introduction video",
    summary:
      "Short-format placeholder title for a future introduction recording.",
    chips: ["Short format", "Local playback", "Three qualities"],
    poster: shortIntroductionPoster,
    defaultQuality: "medium",
    sources: [
      { label: "Low (540p)", value: "low", src: shortIntroductionLow, type: "video/mp4" },
      {
        label: "Medium (720p)",
        value: "medium",
        src: shortIntroductionMedium,
        type: "video/mp4"
      },
      {
        label: "High (1080p)",
        value: "high",
        src: shortIntroductionHigh,
        type: "video/mp4"
      }
    ]
  },
  {
    label: "Video 02",
    title: "Placeholder longer presentation",
    summary:
      "Longer-format placeholder title for a future walkthrough or presentation.",
    chips: ["Longer format", "Poster first", "Quality switch"],
    poster: longerPresentationPoster,
    defaultQuality: "medium",
    sources: [
      { label: "Low (540p)", value: "low", src: longerPresentationLow, type: "video/mp4" },
      {
        label: "Medium (720p)",
        value: "medium",
        src: longerPresentationMedium,
        type: "video/mp4"
      },
      {
        label: "High (1080p)",
        value: "high",
        src: longerPresentationHigh,
        type: "video/mp4"
      }
    ]
  }
] as const;
---

<MainLayout
  title="Videos"
  description="A small video blog for sharing thoughts through short recordings and longer presentations, with on-demand playback and quality selection."
>
  <section class="hero videos-page-hero">
    <p class="eyebrow">Videos</p>
    <h1>Video library</h1>
    <p>
      A small video blog for sharing thoughts on backend engineering, data-heavy systems,
      and the practical trade-offs behind real software work.
    </p>
  </section>

  <section id="video-library" class="section videos-library-section videos-library-section--plain">
    <div class="videos-showcase">
      {videos.map((video) => (
        <div class="videos-entry">
          <div class="videos-entry-head">
            <div class="videos-entry-heading">
              <p class="videos-entry-label">{video.label}</p>
            </div>

            <ul class="videos-entry-chip-list" aria-label={`Highlights for ${video.title}`}>
              {video.chips.map((chip) => (
                <li>{chip}</li>
              ))}
            </ul>
          </div>

          <LazyVideoPlayer
            title={video.title}
            summary={video.summary}
            poster={video.poster}
            sources={video.sources}
            defaultQuality={video.defaultQuality}
          />
        </div>
      ))}
    </div>
  </section>
</MainLayout>
