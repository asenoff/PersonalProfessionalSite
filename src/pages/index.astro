---
import { getCollection } from "astro:content";
import ContentCard from "../components/ContentCard.astro";
import LazyVideoPlayer from "../components/LazyVideoPlayer.astro";
import Section from "../components/Section.astro";
import MainLayout from "../layouts/MainLayout.astro";
import welcomeVideoHigh from "../content/videos/welcome-video-high.mp4?url";
import welcomeVideoLow from "../content/videos/welcome-video-low.mp4?url";
import welcomeVideoMedium from "../content/videos/welcome-video-medium.mp4?url";
import welcomeVideoPoster from "../content/videos/welcome-video-poster.jpg?url";
import { homeContent, siteConfig } from "../data/site";

const workItems = (await getCollection("work"))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 2);

const articleItems = (await getCollection("articles"))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 2);
---

<MainLayout
  title="Home"
  description="Placeholder homepage for Kaloyan Asenov, a senior .NET backend engineer focused on production-critical systems."
>
  <section class="hero">
    <p class="eyebrow">Home</p>
    <h1>{homeContent.hero.title}</h1>
    <p>{homeContent.hero.intro}</p>
    <p>{siteConfig.summary}</p>
    <p>{homeContent.hero.supporting}</p>
  </section>

  <Section title="Core strengths">
    <ul class="simple-list">
      {homeContent.coreStrengths.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </Section>

  <Section title="Best fit">
    <ul class="simple-list">
      {homeContent.bestFit.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </Section>

  <Section title="Selected work preview">
    <div class="card-grid">
      {workItems.map((item) => (
        <ContentCard
          title={item.data.title}
          summary={item.data.summary}
          href={`/work/${item.slug}`}
          tags={item.data.tags}
        />
      ))}
    </div>
    <p class="button-row">
      <a class="button-link button-link--ghost" href="/work">View all work</a>
    </p>
  </Section>

  <Section title="Writing preview">
    <div class="card-grid">
      {articleItems.map((item) => (
        <ContentCard
          title={item.data.title}
          summary={item.data.summary}
          href={`/articles/${item.slug}`}
          tags={item.data.tags}
        />
      ))}
    </div>
    <p class="button-row">
      <a class="button-link button-link--ghost" href="/articles">View all articles</a>
    </p>
  </Section>

  <Section title="Videos">
    <p>A welcome video is available directly on the homepage with on-demand loading.</p>
    <LazyVideoPlayer
      title="Welcome video"
      summary="A lightweight homepage player that loads the selected source only after playback starts."
      poster={welcomeVideoPoster}
      defaultQuality="medium"
      sources={[
        { label: "Low (540p)", value: "low", src: welcomeVideoLow, type: "video/mp4" },
        {
          label: "Medium (720p)",
          value: "medium",
          src: welcomeVideoMedium,
          type: "video/mp4"
        },
        { label: "High (1080p)", value: "high", src: welcomeVideoHigh, type: "video/mp4" }
      ]}
    />
  </Section>

  <Section title="CTA" className="section-callout">
    <p>
      Placeholder call to action for teams that need senior backend help on data-intensive
      or production-critical systems.
    </p>
    <p class="button-row">
      <a class="button-link" href="/contact">Start a conversation</a>
    </p>
  </Section>
</MainLayout>
