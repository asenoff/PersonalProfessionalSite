---
import type { SeoSchemaInput } from "../lib/seo";
import SeoHead from "../components/SeoHead.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { buildDefaultPageSchema } from "../lib/seo";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  robots?: string;
  schema?: SeoSchemaInput;
  ogType?: "website" | "article";
  publishedAt?: string;
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  robots = "index,follow",
  schema,
  ogType = "website",
  publishedAt
} = Astro.props;

const resolvedSchema =
  schema ?? buildDefaultPageSchema({ title, description, path: canonicalPath });
---

<!doctype html>
<html lang="en">
  <head>
    <SeoHead
      title={title}
      description={description}
      canonicalPath={canonicalPath}
      robots={robots}
      schema={resolvedSchema}
      ogType={ogType}
      publishedAt={publishedAt}
    />
  </head>
  <body class="site-shell">
    <a class="skip-link" href="#main-content">Skip to content</a>
    <SiteHeader currentPath={Astro.url.pathname} />
    <main id="main-content" class="container page-content">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
